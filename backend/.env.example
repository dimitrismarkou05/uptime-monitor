# Environment
ENVIRONMENT=development

# Database (Async for FastAPI, Sync for Celery workers)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/uptime
SYNC_DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/uptime

# Redis (Celery broker)
REDIS_URL=redis://localhost:6379/0

# Supabase Auth (#8) — Fill these in when you create your Supabase project
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret

# SMTP / Email Alerts (Mailpit for local dev)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=alerts@uptime-monitor.local